# Shared secret the ESP32 must send in its "hello" message to be accepted
# as the device uplink. Put the SAME value in esp32_bridge_cloud.ino.
RELAY_TOKEN=CHANGE_ME_SHARED_SECRET

# Neon Postgres connection string (from your Neon project dashboard).
# Optional — if omitted, the relay still works, it just won't log history.
# Example: postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Port Render provides at runtime (Render sets this automatically; only
# needed for local testing)
PORT=8080
